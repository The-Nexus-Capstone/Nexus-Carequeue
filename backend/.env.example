# backend/.env
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore already.
# ─────────────────────────────────────────────────────

# ── Flask ──────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string
JWT_SECRET=change-this-to-another-long-random-string

# ── PostgreSQL ─────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# When running via Docker Compose (recommended):
DATABASE_URL=postgresql://carequeue_user:carequeue_pass@db:5432/carequeue
#
# When running Flask locally but Postgres in Docker:
# DATABASE_URL=postgresql://carequeue_user:carequeue_pass@localhost:5432/carequeue
#
# These must match the values below exactly:
POSTGRES_DB=carequeue
POSTGRES_USER=carequeue_user
POSTGRES_PASSWORD=carequeue_pass

# ── Redis / Celery ─────────────────────────────────
REDIS_PASSWORD=change-this-redis-password
REDIS_URL=redis://:change-this-redis-password@redis:6379/0
# Local Redis (if not using Docker):
# REDIS_URL=redis://localhost:6379/0

# ── AI Service ─────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_API_KEY=dev-api-key-change-in-production

# ── Twilio SMS ─────────────────────────────────────
# Leave blank in development — SMS will just print to terminal instead
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ── CORS ───────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
