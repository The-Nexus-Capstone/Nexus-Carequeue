# Copy this file to backend/.env and fill in real values
# Never commit .env to git

# ── Flask ─────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-string
JWT_SECRET=change-this-jwt-secret

# ── Database ──────────────────────────────
DATABASE_URL=postgresql://carequeue_user:carequeue_pass@db:5432/carequeue
POSTGRES_DB=carequeue
POSTGRES_USER=carequeue_user
POSTGRES_PASSWORD=carequeue_pass

# ── Redis / Celery ────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AI Service ────────────────────────────
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_API_KEY=dev-api-key-change-in-production

# ── Twilio SMS ────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ── CORS ──────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend ──────────────────────────────
VITE_API_URL=http://localhost:5000
